# Soda Cloud
SODA_CLOUD_HOST=
SODA_API_KEY_ID=
SODA_API_KEY_SECRET=

# Private index for the licensed `soda` package (soda contract create)
UV_INDEX_SODA_PLATFORM_USERNAME=
UV_INDEX_SODA_PLATFORM_PASSWORD=
UV_INDEX_PYPI_URL=

# Postgres warehouse
DB_SCHEMA=
POSTGRES_HOST=                 # host the local CLI / loaders use
POSTGRES_HOST_SODA_CLOUD=      # in-cluster host the Soda Runner uses
POSTGRES_USERNAME=
POSTGRES_DATABASE=
POSTGRES_PASSWORD=

# BigQuery diagnostics warehouse (agentic failed-rows demo)
BIGQUERY_ACCOUNT_INFO_JSON=

# Live poll (poll/) — Supabase config for the browser app + clear-results.sh.
# gen-config.sh reads these into the gitignored poll/config.js; no keys are committed.
SUPABASE_URL=            # https://<project-ref>.supabase.co
SUPABASE_KEY=            # Supabase publishable/anon key
CLEAR_SECRET=            # shared secret gating the clear_votes RPC
